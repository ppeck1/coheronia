.godot/
.import/
*.import
export.cfg
# R-01: export_presets.cfg is tracked (a committed, reproducible Windows preset).
# Build outputs stay ignored.
/build/
*.translation
*.tmp
*.bak
.DS_Store
Thumbs.db
__pycache__/
*.py[cod]
.project/atlas_outbox/imported/*
!.project/atlas_outbox/imported/.gitkeep
.project/atlas_outbox/rejected/*
!.project/atlas_outbox/rejected/.gitkeep
.project/boh_outbox/imported/*
!.project/boh_outbox/imported/.gitkeep
.project/boh_outbox/rejected/*
!.project/boh_outbox/rejected/.gitkeep

# R-05: private operational evidence stays local. The public_repo profile forbids
# committing raw run ledgers and Atlas/BOH outbox packets (workstation paths and
# internal orchestration detail). Keep only the directory skeletons (.gitkeep).
.project/runs/*.md
.project/atlas_outbox/*.json
.project/boh_outbox/*.json

# FQ-07: smoke-test temp art (written and deleted at runtime; never real assets)
art/generated/*/smoke_tmp_*.png

# FQ-09U: operator-side packaging archives never enter the repo — only the
# rendered OGGs, sources, and tooling are tracked.
audio/**/*.rar
audio/**/*.zip

# Agent session artifacts (never publish)
.codex/
.claude/
__pycache__/
