{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-ops-capsule.local/schemas/run_event.schema.json",
  "title": "Project Ops Run Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "project_id",
    "run_state",
    "started_at",
    "ended_at",
    "repo",
    "scope",
    "non_goals",
    "files_changed",
    "validation_state",
    "readme_state",
    "variable_matrix_state",
    "handoff_state",
    "atlas_sync_state",
    "boh_sync_state",
    "git_state",
    "risk_level",
    "overrides",
    "next_action"
  ],
  "properties": {
    "schema_version": { "const": "0.2" },
    "run_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "run_state": {
      "type": "string",
      "enum": ["SIGNABLE", "PARTIAL", "BLOCKED", "FAILED", "EXPLORATORY", "READ_ONLY_REVIEW"]
    },
    "started_at": { "type": "string" },
    "ended_at": { "type": "string" },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "branch", "remote_url", "start_commit", "end_commit", "dirty_state"],
      "properties": {
        "root": { "type": "string" },
        "branch": { "type": "string" },
        "remote_url": { "type": "string" },
        "start_commit": { "type": "string" },
        "end_commit": { "type": "string" },
        "dirty_state": { "type": "string", "enum": ["clean", "scoped_dirty", "unrelated_dirty", "dirty", "not_repo", "not_checked", "blocked"] }
      }
    },
    "scope": { "type": "string" },
    "non_goals": { "type": "array", "items": { "type": "string" } },
    "files_changed": { "type": "array", "items": { "type": "string" } },
    "validation_state": { "type": "string", "enum": ["pass", "fail", "partial", "not_checked", "blocked"] },
    "readme_state": { "type": "string", "enum": ["updated", "audited_no_change", "not_checked", "blocked", "not_applicable"] },
    "variable_matrix_state": { "type": "string", "enum": ["updated", "no_change_verified", "not_checked", "blocked", "not_applicable"] },
    "handoff_state": { "type": "string", "enum": ["updated", "not_updated_read_only", "not_checked", "blocked", "not_applicable"] },
    "atlas_sync_state": { "type": "string", "enum": ["synced", "queued", "disabled", "blocked", "failed"] },
    "boh_sync_state": { "type": "string", "enum": ["synced", "queued", "disabled", "blocked", "failed"] },
    "git_state": { "type": "string", "enum": ["committed", "clean", "scoped_dirty", "unrelated_dirty", "dirty", "not_repo", "not_checked", "blocked"] },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_skipped", "reason", "risk", "accepted_by", "follow_up_required"],
        "additionalProperties": false,
        "properties": {
          "check_skipped": { "type": "string" },
          "reason": { "type": "string" },
          "risk": { "type": "string" },
          "accepted_by": { "type": "string" },
          "follow_up_required": { "type": "string" }
        }
      }
    },
    "next_action": { "type": "string" }
  }
}

