{
  "schema_version": "0.2",
  "project_id": "coheronia-game",
  "display_name": "Coheronia",
  "root": ".",
  "repo_kind": "software",
  "visibility": "public",
  "profiles": [
    "public_repo",
    "software_project"
  ],
  "canonical_docs": {
    "readme": "README.md",
    "handoff": "docs/HANDOFF.md",
    "variable_matrix": "docs/VARIABLE_MATRIX.md",
    "roadmap": "docs/GAME_FEATURE_OUTLINE.md",
    "architecture": "docs/MVP_VERTICAL_SLICE.md",
    "operations": "docs/PROTOCOL_USAGE.md"
  },
  "validation": {
    "required": [
      "python scripts/validate_repo.py",
      "python _protocol/Project_Ops_Capsule/scripts/capsule_doctor.py . --profile public_repo"
    ],
    "focused": [
      "Godot 4.6.1: open project and check for missing resource/script errors",
      "Godot run: launch res://scenes/shell/Shell.tscn",
      "COHERONIA_SMOKE=1: verify user://smoke_results.json reports PASS"
    ],
    "smoke": [
      "Manual play smoke: create/select character, create/select world, enter game, move, jump, mine, place, torch light, interact with Town Hall, observe C/L/R update, save F5, load F9, Esc returns to shell"
    ],
    "manual": [
      "Do not mark SIGNABLE until docs/MVP_VERTICAL_SLICE.md acceptance table is verified or a narrow exception is recorded"
    ]
  },
  "protected_paths": [
    "reference/g1v5/",
    "_protocol/Project_Ops_Capsule/"
  ],
  "generated_paths": [
    ".project/runs/",
    ".project/atlas_outbox/",
    ".project/boh_outbox/"
  ],
  "secrets_policy": "names-only",
  "atlas_sync": {
    "enabled": true,
    "mode": "outbox",
    "project_key": "coheronia-game"
  },
  "boh_sync": {
    "enabled": true,
    "mode": "outbox",
    "authority": "evidence-only",
    "project_key": "coheronia-game"
  },
  "git_policy": {
    "require_git": true,
    "commit_after_signable_run": true,
    "push_policy": "explicit_operator_request",
    "allow_dirty_unrelated": false
  }
}
